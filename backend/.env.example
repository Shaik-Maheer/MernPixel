NODE_ENV=production
PORT=10000
FRONTEND_URL=https://your-netlify-site.netlify.app

# Database
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/<db-name>?retryWrites=true&w=majority&appName=<app-name>

# OpenAI / OpenRouter-compatible chat config
OPENAI_API_KEY=your_api_key
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openai/gpt-4o-mini
CHATBOT_SYSTEM_PROMPT=You are MernPixel's helpful assistant. Keep answers concise and business-focused.

# Optional (if you add uploads/media APIs)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Optional (if you add email/contact APIs)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
